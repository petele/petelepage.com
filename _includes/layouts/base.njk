<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>{{ renderData.title or title or metadata.title }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Pre-connect to font server -->
    <link rel="preconnect" href="https://fonts.gstatic.com/">

    <!-- SEO description and info -->
    <meta name="description" content="{{ description }}">
    <link rel="canonical" href="{{ metadata.url }}{{ page.url | url }}">

    <!-- Manifest and icons -->
    <link rel="icon" href="/images/favicon.ico">
    <meta name="theme-color" content="#37474F">

    <!-- Default twitter cards -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:url" content="{{ metadata.url }}{{ page.url | url }}">
    <meta name="twitter:title" content="{{ renderData.title or title or metadata.title }}">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="twitter:image" content="{{ image }}">
    <meta name="twitter:creator" content="@petele">

    <!-- Other sharing -->
    <meta property="og:title" content="{{ renderData.title or title or metadata.title }}">
    <meta property="og:type" content="website">
    <meta property="og:image" content="{{ image }}">
    <meta property="og:url" content="{{ metadata.url }}{{ page.url | url }}">
    <meta property="og:description" content="{{ description }}">

    <!-- Styles -->
    <link rel="stylesheet" href="/styles/style.css">
    <link href="https://fonts.googleapis.com/css?family=Roboto|Roboto+Condensed:400,700|Material+Icons" rel="stylesheet">

    <!-- RSS Feed -->
    <link rel="alternate" href="{{ metadata.feed.path | url }}" type="application/atom+xml" title="{{ metadata.title }}">

</head>

<body>

<div id="page" class="hfeed site container">

	<a class="skip-link screen-reader-text" href="#content">Skip to content</a>

	<header id="masthead" class="site-header" role="banner">
		<div id="tabs" class="toggle-tabs">
			<div class="site-header-inside">
				<!-- Logo, description and main navigation -->
				<div class="tab-content current animated fadeIn" role="tabpanel" aria-hidden="false">
					<div class="site-branding">
						<h1 class="site-title">
						  <a href="/" rel="home">Pete LePage</a>
						</h1>
						<h2 class="site-description">
						  Pete's thoughts on the web &amp; other stuff.
						</h2>
					</div>

					<nav id="site-navigation" class="main-navigation" role="navigation">
						<div class="menu-main-menu-container">
						  <ul id="menu-main-menu" class="menu">
						    <li class="menu-item menu-item-type-custom menu-item-object-custom current-menu-item current_page_item menu-item-home">
						      <a href="/">Home</a>
						    </li>
              </ul>
            </div>
					</nav><!-- #site-navigation -->

          <div class="social-links" style="">
            <ul id="menu-social-links" class="menu">
              <li class="menu-item menu-item-type-custom menu-item-object-custom">
                <a href="https://mobile.twitter.com/petele"><span class="screen-reader-text">Twitter</span></a>
              </li>
              <li class="menu-item menu-item-type-custom menu-item-object-custom">
                <a href="https://github.com/petele"><span class="screen-reader-text">GitHub</span></a>
              </li>
            </ul>
          </div>

          <nav id="my-apps-navigation" class="main-navigation" role="navigation">
            <div class="menu-main-menu-container">
              <ul id="menu-main-menu" class="menu">
                <li class="menu-item menu-item-type-custom menu-item-object-custom current-menu-item current_page_item menu-item-home">
                  <a href="https://gdrinker.com">Good Drinker</a>
                </li>
                <li class="menu-item menu-item-type-custom menu-item-object-custom current-menu-item current_page_item menu-item-home">
                  <a href="https://sounddrown.app">Sound Drown</a>
                </li>
              </ul>
            </div>
          </nav><!-- #site-navigation -->
				</div><!-- #tab-1 -->
			</div><!-- .site-header-inside -->
		</div><!-- #tabs -->
	</header><!-- #masthead -->

	<div id="content" class="site-content animated-faster fadeIn">
	  <div id="primary" class="content-area">
		  <main id="main" class="site-main" role="main">

        {{ content | safe }}

		  </main>
		</div>
	</div>

	<footer id="colophon" class="site-footer" role="contentinfo">
	  <div class="site-inner">
  		<div class="site-about">
  		  I'm Pete LePage, a Developer Advocate at Google. I'm based in New York city,
  		  and focus my time helping developers create awesome mobile web experiences.
  		</div>
  		<div class="site-views">
  		  The views and content expressed on this site are mine alone and do not necessarily
  		  reflect the views of my employer, friends, family or pets. Except as otherwise noted,
  		  the content of this blog is licensed under the Creative Commons Attribution 3.0 License,
  		  and code samples are licensed under the Apache license.
  		</div>
  		<div class="site-updated">
  		  Site last updated: {{ lastUpdated }}
  		</div>
		</div>
	</footer><!-- #colophon -->
</div><!-- #page -->

<script>
  /* eslint-disable */
  window.ga=window.ga||function(){(ga.q=ga.q||[]).push(arguments)};ga.l=+new Date;
  // ga('create', 'UA-9988000-4', 'auto');
  // ga('send', 'pageview', '{{ pageURL }}');
  /* esline-enable */
</script>
<script async src="https://www.google-analytics.com/analytics.js"></script>

</body>
</html>
